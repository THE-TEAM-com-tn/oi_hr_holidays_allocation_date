<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Make the Time Off calendar ("Everyone's Time Off") private.

        The hr.leave.report.calendar model (the model behind the calendar view)
        ships in Odoo 17 with ONLY a global multi-company rule, so every employee
        can see everyone's time off on the calendar. We add per-group record rules
        so that:

          - a plain employee (base.group_user)          -> sees only their own
          - a Team Approver (group_hr_holidays_responsible) -> own + their team
          - a Time Off Officer (group_hr_holidays_user)  -> sees everyone
          - a Time Off Administrator (group_hr_holidays_manager) -> sees everyone

        Record rules combine as:
            (AND of global rules) AND (OR of the user's applicable group rules)
        so the permissive Officer/Administrator rules below "open up" the view via
        OR, while a regular member stays constrained to their own records. This
        mirrors the existing privacy already enforced on hr.leave and
        hr.leave.allocation, and reuses Odoo's existing Time Off role dropdown
        (User / Officer / Administrator) - no new groups are introduced.
    -->

    <record id="hr_leave_report_calendar_rule_employee" model="ir.rule">
        <field name="name">Time Off Calendar: employee sees only their own</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_report_calendar"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="hr_leave_report_calendar_rule_responsible" model="ir.rule">
        <field name="name">Time Off Calendar: team approver sees their team</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_report_calendar"/>
        <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.leave_manager_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('hr_holidays.group_hr_holidays_responsible'))]"/>
    </record>

    <record id="hr_leave_report_calendar_rule_officer" model="ir.rule">
        <field name="name">Time Off Calendar: officer sees everyone</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_report_calendar"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_holidays.group_hr_holidays_user'))]"/>
    </record>

    <record id="hr_leave_report_calendar_rule_manager" model="ir.rule">
        <field name="name">Time Off Calendar: administrator sees everyone</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_report_calendar"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_holidays.group_hr_holidays_manager'))]"/>
    </record>

</odoo>
